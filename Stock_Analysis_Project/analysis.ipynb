import yfinance as yf
import pandas as pd
import plotly.express as px

# Download stock data
df = yf.download("AAPL", start="2023-01-01", end="2025-01-01")

# Calculate 20-day moving average
df['MA20'] = df['Close'].rolling(window=20).mean()

# Calculate daily return rate
df['Daily_Return'] = df['Close'].pct_change()

# Plot Stock Price vs 20-Day Moving Average
fig = px.line(df, y=['Close', 'MA20'], title="AAPL Stock Price vs 20-Day Moving Average")
fig.update_layout(xaxis_title="Date", yaxis_title="Price (USD)", legend_title="Indicator")
fig.show()

# Plot Daily Return Distribution to analyze volatility
fig2 = px.histogram(df.dropna(), x='Daily_Return', title="AAPL Daily Return Distribution",
                   marginal="box",
                   labels={'Daily_Return': 'Daily Return'})
fig2.update_layout(xaxis_title="Daily Return", yaxis_title="Frequency")
fig2.show()

# Full Statistical Summary (Required by Instructor)
print("=== Full Statistical Summary ===")
df.describe()