import yfinance as yf
import pandas as pd
import plotly.express as px
import time

# 1. Use Ticker to fetch data, more stable than direct download
ticker = yf.Ticker("AAPL")

# Add request delay to avoid RateLimitError
time.sleep(1)

# Get historical data (using Adjusted Close for accuracy)
df = ticker.history(start="2023-01-01", end="2025-01-01")

# Check if data was retrieved successfully
if not df.empty:
    # 2. Calculate indicators
    # 20-day moving average based on adjusted closing price
    df['MA20'] = df['Adj Close'].rolling(window=20).mean()
    # Daily percentage return
    df['Daily_Return'] = df['Adj Close'].pct_change()

    # 3. Plot: Stock Price vs 20-Day Moving Average
    fig = px.line(
        df,
        y=['Adj Close', 'MA20'],
        title="AAPL Stock Price vs 20-Day Moving Average",
        labels={
            "value": "Price (USD)",
            "index": "Date",
            "variable": "Indicator"
        }
    )
    fig.update_layout(yaxis_title="Price (USD)")
    fig.show()

    # 4. Plot: Daily Return Distribution
    fig2 = px.histogram(
        df.dropna(),
        x='Daily_Return',
        title="AAPL Daily Return Distribution",
        marginal="box",
        labels={"Daily_Return": "Daily Return"}
    )
    fig2.show()

    # 5. Print full statistical summary
    print("=== Full Statistical Summary ===")
    print(df.describe())

else:
    print("Failed to retrieve data. Please try again later or check your internet connection.")